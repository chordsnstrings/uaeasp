# --- Database (DO Managed Postgres connection string in production) ---
DATABASE_URL=postgresql://postgres:devpass@127.0.0.1:5432/uaeasp
# Set to "true" in production (DO managed PG requires TLS)
DATABASE_SSL=false

# --- Site identity (swap when the final domain is registered) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=UAE E-Invoicing Providers

# --- Auth (generate with: openssl rand -base64 32) ---
AUTH_SECRET=change-me
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# --- Scraper ingest ---
# Shared secret between the GitHub Actions scraper and /api/ingest/providers
INGEST_SECRET=change-me-too

# --- Email (any SMTP provider; Resend SMTP recommended) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="UAE E-Invoicing Providers <leads@example.com>"
# Comma-separated list of sales inboxes notified on each new lead
SALES_NOTIFY_EMAILS=
# Single inbox for scrape health / change alerts
ADMIN_ALERT_EMAIL=

# --- Anti-spam ---
# Salt for hashing IP addresses (never store raw IPs)
IP_HASH_SALT=change-me-three
# Optional Cloudflare Turnstile (leave empty to disable)
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# --- AI profile drafts (optional; any OpenAI-compatible API) ---
# When set, newly discovered providers get an auto-drafted EN+AR profile and
# category (fills empty fields only). Leave empty to disable.
# DeepSeek:  AI_API_BASE_URL=https://api.deepseek.com        AI_MODEL=deepseek-chat
# GLM/Zhipu: AI_API_BASE_URL=https://open.bigmodel.cn/api/paas AI_MODEL=glm-4-plus
AI_API_BASE_URL=
AI_API_KEY=
AI_MODEL=

# --- Analytics (optional, Plausible) ---
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
